# Copy this file to .env and fill locally. Do not commit .env.
# Security rule: paste real keys only into local .env, never into chat or git.

# NVIDIA Build / NIM API key from https://build.nvidia.com/
# Usually ONE account-level NVIDIA_API_KEY can be reused across model endpoints.
# Fill this first. Leave the model-specific *_API_KEY entries blank unless NVIDIA
# issues a separate key for that model/page.
NVIDIA_API_KEY=***

# -----------------------------------------------------------------------------
# Current PoC defaults: image-card asset generation
# -----------------------------------------------------------------------------
# For Hanguel we keep only models that passed a real API smoke test.
NVIDIA_IMAGE_ENDPOINT=https://ai.api.nvidia.com/v1/genai/black-forest-labs/flux.1-dev
NVIDIA_IMAGE_MODEL=flux.1-dev
NVIDIA_IMAGE_ASPECT=1:1

# -----------------------------------------------------------------------------
# Active NVIDIA Build model set for Hanguel
# Fill *_API_KEY only if that model requires a separate key. Otherwise use
# NVIDIA_API_KEY above. Failed/deferred models are intentionally omitted.
# -----------------------------------------------------------------------------

# 1) FLUX.1-dev — primary high-quality Hangul/story/card illustration
NVIDIA_FLUX_1_DEV_API_KEY=
NVIDIA_FLUX_1_DEV_BUILD_URL=https://build.nvidia.com/black-forest-labs/flux_1-dev
NVIDIA_FLUX_1_DEV_MODEL=flux.1-dev
NVIDIA_FLUX_1_DEV_ENDPOINT=https://ai.api.nvidia.com/v1/genai/black-forest-labs/flux.1-dev

# 2) Qwen Image — alternate Hangul/card image generation candidate
NVIDIA_QWEN_IMAGE_API_KEY=
NVIDIA_QWEN_IMAGE_BUILD_URL=https://build.nvidia.com/qwen/qwen-image
NVIDIA_QWEN_IMAGE_MODEL=qwen-image
NVIDIA_QWEN_IMAGE_ENDPOINT=https://ai.api.nvidia.com/v1/genai/black-forest-labs/flux.1-dev

# 3) Qwen Image Edit — alternate card variation/edit candidate
NVIDIA_QWEN_IMAGE_EDIT_API_KEY=
NVIDIA_QWEN_IMAGE_EDIT_BUILD_URL=https://build.nvidia.com/qwen/qwen-image-edit
NVIDIA_QWEN_IMAGE_EDIT_MODEL=qwen-image-edit
NVIDIA_QWEN_IMAGE_EDIT_ENDPOINT=https://ai.api.nvidia.com/v1/genai/black-forest-labs/flux.1-dev

# 4) magpie-tts-multilingual — Korean read-aloud / Hani voice candidate
NVIDIA_MAGPIE_TTS_MULTILINGUAL_API_KEY=
NVIDIA_MAGPIE_TTS_MULTILINGUAL_BUILD_URL=https://build.nvidia.com/nvidia/magpie-tts-multilingual
NVIDIA_MAGPIE_TTS_MULTILINGUAL_MODEL=magpie-tts-multilingual
NVIDIA_MAGPIE_TTS_MULTILINGUAL_ENDPOINT=https://877104f7-e885-42b9-8de8-f6e4c6303969.invocation.api.nvcf.nvidia.com/v1/audio/synthesize
NVIDIA_MAGPIE_TTS_MULTILINGUAL_VOICES_ENDPOINT=https://877104f7-e885-42b9-8de8-f6e4c6303969.invocation.api.nvcf.nvidia.com/v1/audio/list_voices
NVIDIA_MAGPIE_TTS_MULTILINGUAL_VOICE=Magpie-Multilingual.EN-US.Aria

# 5) canary-1b-asr — child read-aloud / speech-to-text experiments
NVIDIA_CANARY_1B_ASR_API_KEY=
NVIDIA_CANARY_1B_ASR_BUILD_URL=https://build.nvidia.com/qc69jvmznzxy/canary-1b-asr
NVIDIA_CANARY_1B_ASR_MODEL=canary-1b-asr
NVIDIA_CANARY_1B_ASR_ENDPOINT=

# 6) llama-nemotron-embed-1b-v2 — learning-record retrieval/search
NVIDIA_LLAMA_NEMOTRON_EMBED_1B_V2_API_KEY=
NVIDIA_LLAMA_NEMOTRON_EMBED_1B_V2_BUILD_URL=https://build.nvidia.com/nvidia/llama-nemotron-embed-1b-v2
NVIDIA_LLAMA_NEMOTRON_EMBED_1B_V2_MODEL=llama-nemotron-embed-1b-v2
NVIDIA_LLAMA_NEMOTRON_EMBED_1B_V2_ENDPOINT=

# 7) llama-nemotron-rerank-1b-v2 — review/recommendation reranking
NVIDIA_LLAMA_NEMOTRON_RERANK_1B_V2_API_KEY=
NVIDIA_LLAMA_NEMOTRON_RERANK_1B_V2_BUILD_URL=https://build.nvidia.com/nvidia/llama-nemotron-rerank-1b-v2
NVIDIA_LLAMA_NEMOTRON_RERANK_1B_V2_MODEL=llama-nemotron-rerank-1b-v2
NVIDIA_LLAMA_NEMOTRON_RERANK_1B_V2_ENDPOINT=

# 8) llama-3.1-nemotron-nano-vl-8b-v1 — image/handwriting feedback experiments
NVIDIA_LLAMA_3_1_NEMOTRON_NANO_VL_8B_V1_API_KEY=
NVIDIA_LLAMA_3_1_NEMOTRON_NANO_VL_8B_V1_BUILD_URL=https://build.nvidia.com/nvidia/llama-3.1-nemotron-nano-vl-8b-v1
NVIDIA_LLAMA_3_1_NEMOTRON_NANO_VL_8B_V1_MODEL=llama-3.1-nemotron-nano-vl-8b-v1
NVIDIA_LLAMA_3_1_NEMOTRON_NANO_VL_8B_V1_ENDPOINT=

# 9) nemotron-ocr-v2 — OCR / generated-card text sanity checks
NVIDIA_NEMOTRON_OCR_V2_API_KEY=
NVIDIA_NEMOTRON_OCR_V2_BUILD_URL=https://build.nvidia.com/nvidia/nemotron-ocr-v2
NVIDIA_NEMOTRON_OCR_V2_MODEL=nemotron-ocr-v2
NVIDIA_NEMOTRON_OCR_V2_ENDPOINT=

# 10) nemotron-3-content-safety — child-facing generated content moderation
NVIDIA_NEMOTRON_3_CONTENT_SAFETY_API_KEY=
NVIDIA_NEMOTRON_3_CONTENT_SAFETY_BUILD_URL=https://build.nvidia.com/nvidia/nemotron-3-content-safety
NVIDIA_NEMOTRON_3_CONTENT_SAFETY_MODEL=nemotron-3-content-safety
NVIDIA_NEMOTRON_3_CONTENT_SAFETY_ENDPOINT=
